#!/usr/bin/env bash
# .githooks/pre-push — runs before `git push`.
#
# Single job: catch the 2026-04-15 class of failure locally before it
# eats 11 CI cycles. `python -c "import main"` resolves every transitive
# import in mcp-server/main.py; a typo in any imported module fails in
# under a second with a clear stacktrace.
#
# Activate on a fresh clone:
#
#     scripts/setup-hooks.sh
#
# Skip in emergencies (DOESN'T happen often; the hook runs fast enough
# that the Normal path is always cheaper than the bypass):
#
#     git push --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Determine which subsystems the push touches. We gate two separate
# local checks: (a) Python smoke-import for backend, (b) source-level
# iso pytests for iso/*. Each only runs when relevant — infra-only
# doc pushes stay under a second.
CHANGED=$(git diff --name-only "@{u}..HEAD" 2>/dev/null || git diff --name-only "HEAD~5..HEAD")
BACKEND_CHANGED=0
ISO_CHANGED=0
FRONTEND_CHANGED=0
# Silent-skip-class fix (Task #68, 2026-05-13):
# `git diff @{u}..HEAD` exits 0 with EMPTY stdout when HEAD == upstream
# (the exact state during manual verification reruns AFTER a successful
# push). The `||` fallback only triggers on non-zero exit, not on empty
# stdout. Result: $CHANGED is empty, the for-loop iterates zero times,
# all flags stay 0, every gate silently skips, exit 0. That's how
# commit fd54e637 (Phase 2c canonical_compliance_score_drift) deployed
# with a missing ## Escalation runbook section — author's manual
# re-verify showed rc=0 because the empty-stdout case hit ALL flags=0.
# Fix: if $CHANGED is empty, force all flags to 1 (treat as manual
# verification mode — run every gate). Docs-only changes still skip
# all gates because $CHANGED would be non-empty but contain no
# mcp-server/* or iso/* entries.
if [ -z "$CHANGED" ]; then
    echo "[pre-push] manual-verification mode (HEAD == @{u} or no upstream) — running all gates"
    BACKEND_CHANGED=1
    ISO_CHANGED=1
    FRONTEND_CHANGED=1
else
    for f in $CHANGED; do
        case "$f" in
            mcp-server/central-command/frontend/*) FRONTEND_CHANGED=1 ;;
            mcp-server/*) BACKEND_CHANGED=1 ;;
            iso/*)        ISO_CHANGED=1 ;;
        esac
    done
fi

# Backend smoke-import (catches the 2026-04-15 ImportError-on-deploy class).
if [ "$BACKEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] smoke-import check..."
    cd "$REPO_ROOT/mcp-server"
    if ! python3 -c "import main" >/dev/null 2>&1; then
        echo "[pre-push] ❌ import main failed — push blocked"
        echo ""
        python3 -c "import main" 2>&1 | sed -n '/Traceback\|Error/,/^$/p' | head -20
        echo ""
        echo "[pre-push] Fix the import error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ import main clean"
    cd "$REPO_ROOT"

    # CI Python parity check (RT33 deploy outage, 2026-05-05). CI runs
    # Python 3.11; local devs may be on 3.13/3.14 which accepts more
    # syntax (e.g. backslashes in f-string expressions). Three RT33
    # deploys failed because a test file used 3.12+ syntax that 3.11
    # rejects at collection time. Pre-push compiles every backend .py
    # file with python3.11 if available — fast, catches the exact class.
    if command -v python3.11 >/dev/null 2>&1; then
        echo "[pre-push] CI Python 3.11 syntax check..."
        BACKEND_DIR="$REPO_ROOT/mcp-server/central-command/backend"
        if ! find "$BACKEND_DIR" -name "*.py" \
            -not -path "*/venv/*" -not -path "*/.venv/*" \
            -print0 | xargs -0 python3.11 -m py_compile 2>/tmp/py311-prepush.log; then
            echo "[pre-push] ❌ Python 3.11 syntax check failed — push blocked"
            echo ""
            tail -20 /tmp/py311-prepush.log
            echo ""
            echo "[pre-push] CI runs Python 3.11. Fix the syntax (e.g."
            echo "[pre-push] backslash in f-string expr), then re-push."
            exit 1
        fi
        echo "[pre-push] ✓ Python 3.11 syntax clean"
    fi
fi

