    echo "[pre-push] source-level governance pytests..."
    cd "$REPO_ROOT/mcp-server/central-command/backend"
    if ! python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=line >/dev/null 2>&1; then
        echo "[pre-push] ❌ governance pytest failed — push blocked"
        echo ""
        python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=short 2>&1 | tail -30
        echo ""
        echo "[pre-push] Fix the regression, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ backend pytest clean"
    cd "$REPO_ROOT"
fi

# Full-CI-parity backend test sweep (Session 218 round-table 2026-05-06).
#
# The SOURCE_LEVEL_TESTS list above is a CURATED fast lane (~45s).
# On 2026-05-06 deploy 18af959c failed at CI on
# test_auditor_kit_endpoint.py — that test was NOT in the curated
# list but WAS in CI. Local pre-push said clean; CI failed.
#
# Helper script .githooks/full-test-sweep.sh mirrors CI's exact
# behavior: walks every tests/test_*.py, runs each in its own
# subprocess (matches CI's stub-isolation), parallel `-P 6` for
# ~92s wall on a fully-equipped dev box. Collection errors caused
# by missing backend deps (asyncpg, pynacl, pydantic_core, nacl,
# sqlalchemy.ext.asyncio, aiohttp, cryptography, google.auth) are
# treated as SKIPPED — those run server-side. Real assertion
# failures are FATAL.
#
# Opt-out: PRE_PUSH_SKIP_FULL=1 git push (use sparingly).
# Tune parallelism: PRE_PUSH_PARALLEL=N (default 6).
if [ "$BACKEND_CHANGED" -eq 1 ] && [ "${PRE_PUSH_SKIP_FULL:-0}" != "1" ]; then
    echo "[pre-push] full backend test sweep (CI parity)..."
    if ! bash "$REPO_ROOT/.githooks/full-test-sweep.sh" \
            "$REPO_ROOT/mcp-server/central-command/backend"; then
        echo ""
        echo "[pre-push] ❌ full backend sweep failed — push blocked"
        echo "[pre-push] Real test failures above. Fix or use"
        echo "[pre-push]   PRE_PUSH_SKIP_FULL=1 git push (emergency only)"
        echo "[pre-push] Bypass entirely: git push --no-verify"
        exit 1
    fi
fi

# Stem-matched targeted backend pytest (Session 212 round-table angle 4 P1).
# Opt-in via PRE_PUSH_FULL=1 so dev pushes that lack asyncpg/pynacl
# don't get blocked. When enabled, walks the changed-source filenames
# and runs any test_*.py whose stem corresponds. Catches the
# `test_flywheel_promote.py` vs `test_flywheel_promotion.py` silent-
# skip class — pre-fix I'd run the latter, miss the former, ship.
if [ "${PRE_PUSH_FULL:-0}" = "1" ] && [ "$BACKEND_CHANGED" -eq 1 ]; then
    cd "$REPO_ROOT/mcp-server/central-command/backend"
    STEMS=()
    for f in $CHANGED; do
        case "$f" in
            mcp-server/central-command/backend/*.py)
                base=$(basename "$f" .py)
                # Match by exact stem first, then by prefix (covers
                # both test_flywheel_promote_candidate.py and the legacy
                # test_flywheel_promotion.py for changes to flywheel_promote.py).
                for t in tests/test_${base}.py tests/test_${base}_*.py tests/test_*${base}*.py; do
                    [ -f "$t" ] && STEMS+=("$t")
                done
                ;;
        esac
    done
    if [ "${#STEMS[@]}" -gt 0 ]; then
        # Dedup
        STEMS=($(printf '%s\n' "${STEMS[@]}" | sort -u))
        echo "[pre-push] PRE_PUSH_FULL=1 — stem-matched pytest (${#STEMS[@]} files)..."
        if ! python3 -m pytest "${STEMS[@]}" -q --tb=line >/dev/null 2>&1; then
            echo "[pre-push] ❌ stem-matched pytest failed — push blocked"
            python3 -m pytest "${STEMS[@]}" -q --tb=short 2>&1 | tail -25
            echo ""
            echo "[pre-push] If failures are import-deps the dev box doesn't have,"
            echo "[pre-push] unset PRE_PUSH_FULL or use --no-verify (emergency)."
            exit 1
        fi
        echo "[pre-push] ✓ stem-matched pytest clean"
    fi
    cd "$REPO_ROOT"
fi

# Frontend TypeScript check (Session 212 round-table angle 2 P0).
# 2026-04-28 deploy cascade: a single TS2322 in commit 0c81fef6
# bricked SIX consecutive deploys for ~90 minutes because the bug
# carried forward across each subsequent push. The CLAUDE.md rule
# "run tsc+eslint+pytest locally BEFORE push" was documentation, not
# policy — this hook makes it policy.
if [ "$FRONTEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] frontend tsc --noEmit ..."
    cd "$REPO_ROOT/mcp-server/central-command/frontend"
    if ! npx tsc --noEmit > /tmp/tsc-prepush.log 2>&1; then
        echo "[pre-push] ❌ tsc failed — push blocked"
        echo ""
        tail -30 /tmp/tsc-prepush.log
        echo ""
        echo "[pre-push] Fix the type error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ frontend tsc clean"

    # ESLint gate (Session 217 closure of CI deploy 25384660361 lint
    # failure, 2026-05-05). Pre-push tsc had been catching type errors
    # but not lint — `score == null` (eqeqeq) tripped CI after passing
    # local pre-push. Now lint runs in the same gate as tsc. Scoped to
    # the touched portal directories where the deploys actually fail
    # (full-repo lint takes ~45s; this is ~6s).
    echo "[pre-push] frontend eslint ..."
    if ! npx eslint src/client src/partner src/components > /tmp/eslint-prepush.log 2>&1; then
        echo "[pre-push] ❌ eslint failed — push blocked"
        echo ""
        tail -30 /tmp/eslint-prepush.log
        echo ""
        echo "[pre-push] Fix the lint error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ frontend eslint clean"
    cd "$REPO_ROOT"
fi
