#!/usr/bin/env bash
# .githooks/pre-push — runs before `git push`.
#
# Single job: catch the 2026-04-15 class of failure locally before it
# eats 11 CI cycles. `python -c "import main"` resolves every transitive
# import in mcp-server/main.py; a typo in any imported module fails in
# under a second with a clear stacktrace.
#
# Activate on a fresh clone:
#
#     scripts/setup-hooks.sh
#
# Skip in emergencies (DOESN'T happen often; the hook runs fast enough
# that the Normal path is always cheaper than the bypass):
#
#     git push --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Determine which subsystems the push touches. We gate two separate
# local checks: (a) Python smoke-import for backend, (b) source-level
# iso pytests for iso/*. Each only runs when relevant — infra-only
# doc pushes stay under a second.
CHANGED=$(git diff --name-only "@{u}..HEAD" 2>/dev/null || git diff --name-only "HEAD~5..HEAD")
BACKEND_CHANGED=0
ISO_CHANGED=0
FRONTEND_CHANGED=0
for f in $CHANGED; do
    case "$f" in
        mcp-server/central-command/frontend/*) FRONTEND_CHANGED=1 ;;
        mcp-server/*) BACKEND_CHANGED=1 ;;
        iso/*)        ISO_CHANGED=1 ;;
    esac
done

# Backend smoke-import (catches the 2026-04-15 ImportError-on-deploy class).
if [ "$BACKEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] smoke-import check..."
    cd "$REPO_ROOT/mcp-server"
    if ! python3 -c "import main" >/dev/null 2>&1; then
        echo "[pre-push] ❌ import main failed — push blocked"
        echo ""
        python3 -c "import main" 2>&1 | sed -n '/Traceback\|Error/,/^$/p' | head -20
        echo ""
        echo "[pre-push] Fix the import error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ import main clean"
    cd "$REPO_ROOT"
fi

# Source-level governance pytests (v40.5 round-table post-audit,
# 2026-04-24). These tests read .nix / .py / .md files with
# pathlib+regex; they do NOT require backend deps (asyncpg, pynacl,
# pydantic v2) and run cleanly on the dev Python that isn't locked
# to CI's pinned image. The full CI test suite still runs server-
# side; this is the fast local gate that would have caught all 5 of
# today's CI regressions (test_iso_msp_narrow_sudo + two on
# test_assertion_metadata_complete + test_substrate_docs_present +
# migration 240 line — the last needs server-side because it's a
# deploy-time SQL error, out of scope for source checks).
#
# Each test file listed has been verified to run without backend
# imports. Do NOT add test_*_pg.py or dep-heavy tests here — they
# fail to collect locally and would turn every push into a --no-verify.
SOURCE_LEVEL_TESTS=(
    "tests/test_iso_breakglass_phase0.py"
    "tests/test_iso_firewall_no_runtime_dns.py"
    "tests/test_iso_install_gate.py"
    "tests/test_iso_msp_narrow_sudo.py"
    "tests/test_iso_v40_3_classpath.py"
    "tests/test_iso_v40_4_self_heal.py"
    "tests/test_iso_v40_6_config_yaml_flat.py"
    "tests/test_iso_v40_8_appliance_id_in_config.py"
    "tests/test_assertion_metadata_complete.py"
    "tests/test_substrate_docs_present.py"
    "tests/test_pydantic_contract_check.py"
    "tests/test_openapi_schema_in_sync.py"
    "tests/test_consumer_contract_check.py"
    "tests/test_client_telemetry_ingest.py"
    "tests/test_ci_prod_version_lockstep.py"
    "tests/test_lifespan_imports_resolve.py"
    # Added 2026-05-02 followup #46: pre-push CI parity. The 675fa1a6
    # CI failure was test_sql_columns_match_schema not seeing mig 271's
    # new column — pre-push didn't include it. Grandfathering critical
    # source-level governance gates so pre-push mirrors CI for this
    # class. Verified each runs without backend deps (asyncpg, pynacl,
    # pydantic v2). Add to this list when shipping a new source-level
    # CI gate; do NOT add *_pg.py tests (DB-gated, would fail to collect).
    "tests/test_sql_columns_match_schema.py"
    "tests/test_check_constraint_fits_column.py"
    "tests/test_no_silent_write_warnings.py"
    "tests/test_test_filename_uniqueness.py"
    "tests/test_no_unfiltered_site_appliances_select.py"
    "tests/test_compliance_status_not_read.py"
    "tests/test_no_sql_function_interval_concat.py"
    "tests/test_canonical_not_used_for_compliance_bundles.py"
    "tests/test_no_direct_site_id_update.py"
    "tests/test_admin_transaction_for_multistatement.py"
    "tests/test_frontend_mutation_csrf.py"
    "tests/test_no_same_origin_credentials.py"
    "tests/test_no_stdlib_logger_kwargs.py"
    "tests/test_loop_records_heartbeat.py"
    "tests/test_smtp_consolidation_lockstep.py"
    "tests/test_mfa_admin_overrides.py"
    "tests/test_mfa_revocation_reason_check_constraint.py"
    "tests/test_client_user_email_rename.py"
    "tests/test_per_control_lockstep.py"
    "tests/test_no_inline_score_thresholds.py"
    "tests/test_expected_interval_calibration.py"
    "tests/test_go_agent_terminal_status_lockstep.py"
    # 8 additional TIER-1 gates surfaced by test_pre_push_ci_parity gate
    # (2026-05-02 followup #46). All verified to collect without
    # backend deps. The pre_push_ci_parity test enforces this list
    # stays in sync with new TIER-1 tests by naming convention.
    "tests/test_admin_audit_log_column_lockstep.py"
    "tests/test_canonical_site_id_function.py"
    "tests/test_iso_ca.py"
    "tests/test_no_site_wide_update.py"
    "tests/test_pre_push_ci_parity.py"
    "tests/test_privileged_order_four_list_lockstep.py"
    "tests/test_sql_filter_attaches_to_aggregate.py"
    "tests/test_sql_on_conflict_uniqueness.py"
    # AI-independence audit dim 8 (2026-05-02). Pins the cryptographic-
    # chain LLM-free property as a ratchet. Any future PR adding LLM
    # imports to a chain-component file fails CI.
    "tests/test_compliance_chain_llm_free.py"
    "tests/test_data_completeness_field.py"
    "tests/test_auditor_kit_disclosures.py"
    "tests/test_kill_switch_endpoints.py"
    "tests/test_compliance_packet_timeout_override.py"
    "tests/test_kill_switch_portal_disclosure.py"
    "tests/test_admin_billing_destructive.py"
    "tests/test_privileged_chain_allowed_events_lockstep.py"
)
if [ "$ISO_CHANGED" -eq 1 ] || [ "$BACKEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] source-level governance pytests..."
    cd "$REPO_ROOT/mcp-server/central-command/backend"
    if ! python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=line >/dev/null 2>&1; then
        echo "[pre-push] ❌ governance pytest failed — push blocked"
        echo ""
        python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=short 2>&1 | tail -30
        echo ""
        echo "[pre-push] Fix the regression, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ backend pytest clean"
    cd "$REPO_ROOT"
fi

# Stem-matched targeted backend pytest (Session 212 round-table angle 4 P1).
# Opt-in via PRE_PUSH_FULL=1 so dev pushes that lack asyncpg/pynacl
# don't get blocked. When enabled, walks the changed-source filenames
# and runs any test_*.py whose stem corresponds. Catches the
# `test_flywheel_promote.py` vs `test_flywheel_promotion.py` silent-
# skip class — pre-fix I'd run the latter, miss the former, ship.
if [ "${PRE_PUSH_FULL:-0}" = "1" ] && [ "$BACKEND_CHANGED" -eq 1 ]; then
    cd "$REPO_ROOT/mcp-server/central-command/backend"
    STEMS=()
    for f in $CHANGED; do
        case "$f" in
            mcp-server/central-command/backend/*.py)
                base=$(basename "$f" .py)
                # Match by exact stem first, then by prefix (covers
                # both test_flywheel_promote_candidate.py and the legacy
                # test_flywheel_promotion.py for changes to flywheel_promote.py).
                for t in tests/test_${base}.py tests/test_${base}_*.py tests/test_*${base}*.py; do
                    [ -f "$t" ] && STEMS+=("$t")
                done
                ;;
        esac
    done
    if [ "${#STEMS[@]}" -gt 0 ]; then
        # Dedup
        STEMS=($(printf '%s\n' "${STEMS[@]}" | sort -u))
        echo "[pre-push] PRE_PUSH_FULL=1 — stem-matched pytest (${#STEMS[@]} files)..."
        if ! python3 -m pytest "${STEMS[@]}" -q --tb=line >/dev/null 2>&1; then
            echo "[pre-push] ❌ stem-matched pytest failed — push blocked"
            python3 -m pytest "${STEMS[@]}" -q --tb=short 2>&1 | tail -25
            echo ""
            echo "[pre-push] If failures are import-deps the dev box doesn't have,"
            echo "[pre-push] unset PRE_PUSH_FULL or use --no-verify (emergency)."
            exit 1
        fi
        echo "[pre-push] ✓ stem-matched pytest clean"
    fi
    cd "$REPO_ROOT"
fi

# Frontend TypeScript check (Session 212 round-table angle 2 P0).
# 2026-04-28 deploy cascade: a single TS2322 in commit 0c81fef6
# bricked SIX consecutive deploys for ~90 minutes because the bug
# carried forward across each subsequent push. The CLAUDE.md rule
# "run tsc+eslint+pytest locally BEFORE push" was documentation, not
# policy — this hook makes it policy.
if [ "$FRONTEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] frontend tsc --noEmit ..."
    cd "$REPO_ROOT/mcp-server/central-command/frontend"
    if ! npx tsc --noEmit > /tmp/tsc-prepush.log 2>&1; then
        echo "[pre-push] ❌ tsc failed — push blocked"
        echo ""
        tail -30 /tmp/tsc-prepush.log
        echo ""
        echo "[pre-push] Fix the type error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ frontend tsc clean"
    cd "$REPO_ROOT"
fi
