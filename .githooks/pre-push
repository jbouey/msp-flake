#!/usr/bin/env bash
# .githooks/pre-push — runs before `git push`.
#
# Single job: catch the 2026-04-15 class of failure locally before it
# eats 11 CI cycles. `python -c "import main"` resolves every transitive
# import in mcp-server/main.py; a typo in any imported module fails in
# under a second with a clear stacktrace.
#
# Activate on a fresh clone:
#
#     scripts/setup-hooks.sh
#
# Skip in emergencies (DOESN'T happen often; the hook runs fast enough
# that the Normal path is always cheaper than the bypass):
#
#     git push --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Determine which subsystems the push touches. We gate two separate
# local checks: (a) Python smoke-import for backend, (b) source-level
# iso pytests for iso/*. Each only runs when relevant — infra-only
# doc pushes stay under a second.
CHANGED=$(git diff --name-only "@{u}..HEAD" 2>/dev/null || git diff --name-only "HEAD~5..HEAD")
BACKEND_CHANGED=0
ISO_CHANGED=0
for f in $CHANGED; do
    case "$f" in
        mcp-server/*) BACKEND_CHANGED=1 ;;
        iso/*)        ISO_CHANGED=1 ;;
    esac
done

# Backend smoke-import (catches the 2026-04-15 ImportError-on-deploy class).
if [ "$BACKEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] smoke-import check..."
    cd "$REPO_ROOT/mcp-server"
    if ! python3 -c "import main" >/dev/null 2>&1; then
        echo "[pre-push] ❌ import main failed — push blocked"
        echo ""
        python3 -c "import main" 2>&1 | sed -n '/Traceback\|Error/,/^$/p' | head -20
        echo ""
        echo "[pre-push] Fix the import error, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ import main clean"
    cd "$REPO_ROOT"
fi

# Source-level governance pytests (v40.5 round-table post-audit,
# 2026-04-24). These tests read .nix / .py / .md files with
# pathlib+regex; they do NOT require backend deps (asyncpg, pynacl,
# pydantic v2) and run cleanly on the dev Python that isn't locked
# to CI's pinned image. The full CI test suite still runs server-
# side; this is the fast local gate that would have caught all 5 of
# today's CI regressions (test_iso_msp_narrow_sudo + two on
# test_assertion_metadata_complete + test_substrate_docs_present +
# migration 240 line — the last needs server-side because it's a
# deploy-time SQL error, out of scope for source checks).
#
# Each test file listed has been verified to run without backend
# imports. Do NOT add test_*_pg.py or dep-heavy tests here — they
# fail to collect locally and would turn every push into a --no-verify.
SOURCE_LEVEL_TESTS=(
    "tests/test_iso_breakglass_phase0.py"
    "tests/test_iso_firewall_no_runtime_dns.py"
    "tests/test_iso_install_gate.py"
    "tests/test_iso_msp_narrow_sudo.py"
    "tests/test_iso_v40_3_classpath.py"
    "tests/test_iso_v40_4_self_heal.py"
    "tests/test_iso_v40_6_config_yaml_flat.py"
    "tests/test_assertion_metadata_complete.py"
    "tests/test_substrate_docs_present.py"
)
if [ "$ISO_CHANGED" -eq 1 ] || [ "$BACKEND_CHANGED" -eq 1 ]; then
    echo "[pre-push] source-level governance pytests..."
    cd "$REPO_ROOT/mcp-server/central-command/backend"
    if ! python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=line >/dev/null 2>&1; then
        echo "[pre-push] ❌ governance pytest failed — push blocked"
        echo ""
        python3 -m pytest "${SOURCE_LEVEL_TESTS[@]}" -q --tb=short 2>&1 | tail -30
        echo ""
        echo "[pre-push] Fix the regression, then re-push."
        echo "[pre-push] Bypass (emergency only): git push --no-verify"
        exit 1
    fi
    echo "[pre-push] ✓ backend pytest clean"
    cd "$REPO_ROOT"
fi
